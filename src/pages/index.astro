---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostListItem from '../components/PostListItem.astro';
import Icon from '../components/Icon.astro';
import { SOCIAL_LINKS } from '../consts';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const recent = posts.slice(0, 5);
---

<BaseLayout>
  <section class="wrapper hero">
    <p class="eyebrow">~ whoami</p>
    <h1 class="hero-title">
      Josh English
    </h1>
    <p class="hero-role">
      Full-stack software engineer at <span class="hl">AWS</span>
    </p>
    <p class="hero-bio">
      I'm a full-stack engineer who likes building things people actually use.
      Right now I'm finishing an MS in CS at Georgia Tech (OMSCS) on nights and
      weekends. Away from the keyboard: motorcycles, finance rabbit holes, wine,
      and a golf game that isn't getting any better.
    </p>

    <div class="hero-links">
      <a class="btn" href="/blog/">Read the blog</a>
      <div class="hero-socials">
        {
          SOCIAL_LINKS.filter((l) => l.icon !== 'rss').map((link) => (
            <a
              class="social"
              href={link.href}
              aria-label={link.name}
              title={link.name}
              rel={link.href.startsWith('http') ? 'me noopener' : undefined}
              target={link.href.startsWith('http') ? '_blank' : undefined}
            >
              <Icon name={link.icon} />
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="wrapper writing">
    <div class="section-head">
      <h2>Writing</h2>
      <a class="see-all" href="/blog/">All posts →</a>
    </div>
    <div class="post-list">
      {recent.map((post) => <PostListItem post={post} />)}
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-block: var(--space-l) var(--space-xl);
  }
  .hero-title {
    margin: var(--space-2xs) 0 0;
  }
  .hero-role {
    font-size: var(--step-1);
    color: var(--text-muted);
    margin: var(--space-2xs) 0 var(--space-s);
  }
  .hl {
    color: var(--text);
    font-weight: 600;
  }
  .hero-bio {
    max-width: 38rem;
    color: var(--text);
    font-size: var(--step-0);
  }
  .hero-links {
    display: flex;
    align-items: center;
    gap: var(--space-m);
    flex-wrap: wrap;
    margin-top: var(--space-m);
  }
  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.55rem 1.1rem;
    font-weight: 600;
    font-size: var(--step--1);
    color: var(--accent-contrast);
    background: var(--accent);
    border-radius: var(--radius-sm);
    transition: background var(--dur) var(--ease), transform var(--dur) var(--ease);
  }
  .btn:hover {
    background: var(--accent-hover);
    text-decoration: none;
    transform: translateY(-1px);
  }
  .hero-socials {
    display: flex;
    gap: var(--space-2xs);
  }
  .social {
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    color: var(--text-muted);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    transition: color var(--dur) var(--ease), border-color var(--dur) var(--ease),
      background var(--dur) var(--ease);
  }
  .social:hover {
    color: var(--accent);
    border-color: var(--accent);
    background: var(--surface);
    text-decoration: none;
  }

  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-s);
    border-bottom: 1px solid var(--border);
    padding-bottom: var(--space-2xs);
    margin-bottom: var(--space-s);
  }
  .section-head h2 {
    margin: 0;
    font-size: var(--step-1);
  }
  .see-all {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--text-muted);
  }
  .see-all:hover {
    color: var(--accent);
    text-decoration: none;
  }
</style>
